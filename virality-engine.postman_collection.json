{
  "info": {
    "name": "Virality Engine",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"USER\",\n  \"content\": \"Hello world\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/posts",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "posts"]
        }
      }
    },
    {
      "name": "Add Comment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 2,\n  \"authorType\": \"BOT\",\n  \"content\": \"Great post!\",\n  \"depthLevel\": 1\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/posts/1/comments",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "posts", "1", "comments"]
        }
      }
    },
    {
      "name": "Like Post",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 3,\n  \"authorType\": \"USER\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/posts/1/like",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "posts", "1", "like"]
        }
      }
    }
  ]
}
